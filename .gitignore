# Downloaded CMS data — large, reproducible from documented source URLs. Never commit.
# Also excludes the real ground-truth inputs (plan.txt/meds.txt/expected.txt = PII).
# Ignore the contents of data/ but NOT the dir itself, so the templates can be tracked.
/data/*
*.zip

# ...but DO track the input templates so the expected format is documented in-repo.
!data/*.template

# DO track the small MO ZIP/SSA/FIPS crosswalks — public-domain reference data, tiny, and
# the deterministic source ingest loads (rebuild with `node scripts/build_crosswalks.js`).
!data/crosswalks/
!data/crosswalks/*.txt

# Local embedded-Postgres data dir (regenerable via `npm run ingest`)
.pglite/

# Cloudflare Wrangler local state
.wrangler/

# Local editor/agent settings
.claude/settings.local.json

# Node
node_modules/
npm-debug.log*

# Playwright / UX floor suite artifacts (the suite + its fixtures ARE tracked)
/test-results/
/playwright-report/
/tests/ux/report/

# OS
.DS_Store
Thumbs.db

# Generated pipeline outputs — reproducible by re-running the scripts, and they
# contain her meds/plan (health PII). Keep the dir, ignore the contents.
/out/*
!out/.gitkeep

# brand rollout scratch + redundant source archive (extracted into brand/)
_brandtmp/
PlanRobin_Concepts.zip
